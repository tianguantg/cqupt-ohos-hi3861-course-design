# Firmware and executables are ignored by default.
# Explicit exceptions below keep the curated teaching deliverables.
*.bin
*.exe
!firmware/final/*.bin
!comfort-fan-final-package/firmware/*.bin
!resources/tools/HiBurn.exe

# Archives are ignored by default except curated resources and releases.
*.zip
*.7z
*.rar
!releases/*.zip
!resources/vendor-kits/**/*.zip

# Logs
*.log
!comfort-fan-final-package/evidence/*.md
!comfort-fan-final-package/evidence/*.log

# Local historical archives are retained on disk but not tracked wholesale.
archive/**
!archive/
!archive/README.md
!archive/docs/
!archive/docs/*.md
