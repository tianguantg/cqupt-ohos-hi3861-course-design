# 源码文本文件 — 统一 LF 换行
*.md       text eol=lf
*.txt      text eol=lf
*.c        text eol=lf
*.h        text eol=lf
*.json     text eol=lf
*.gn       text eol=lf
*.mk       text eol=lf
*.py       text eol=lf
*.xml      text eol=lf
*.cfg      text eol=lf
*.ini      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
Makefile   text eol=lf
SConscript text eol=lf
SConstruct text eol=lf
BUILD.gn   text eol=lf
LICENSE    text eol=lf

# 二进制文件 — 不进行文本 diff
*.docx     binary -text
*.pptx     binary -text
*.pdf      binary -text
*.PDF      binary -text
*.zip      binary -text
*.png      binary -text
*.jpg      binary -text
*.jpeg     binary -text
*.gif      binary -text
*.bmp      binary -text
*.ico      binary -text
*.ttf      binary -text
*.woff     binary -text
*.woff2    binary -text

# 如后续资料体积明显增长，可在仓库启用 Git LFS 后再添加 filter=lfs 规则。
